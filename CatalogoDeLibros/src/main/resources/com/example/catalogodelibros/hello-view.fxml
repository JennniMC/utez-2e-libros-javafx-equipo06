<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.catalogodelibros.HelloController">

    <TableView fx:id="tablaLibros" style="-fx-focus-color: transparent; -fx-faint-focus-color: transparent;" prefHeight="200">
        <columns>
            <TableColumn fx:id="colId" text="ID"/>
            <TableColumn fx:id="colTitulo" text="Título"/>
            <TableColumn fx:id="colAutor" text="Autor"/>
            <TableColumn fx:id="colYear" text="Año"/>
            <TableColumn fx:id="colGenero" text="Género"/>
            <TableColumn fx:id="colDisponible" text="Disponible"/>
        </columns>
    </TableView>

    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <TextField fx:id="txtId" promptText="ID" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtTitulo" promptText="Título" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <TextField fx:id="txtAutor" promptText="Autor" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtYear" promptText="Año" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <ComboBox fx:id="cmbGenero" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <CheckBox fx:id="chkDisponible" text="Disponible" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Agregar" onAction="#agregarLibro" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Eliminar" onAction="#eliminarLibro" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        <Button text="Recargar" onAction="#recargarDatos" style="-fx-background-color: #5027F5; -fx-text-fill: white;"/>
        <Button text="Modificar" onAction="#modificarBook" style="-fx-background-color: #F52746; -fx-text-fill: white;" />
        <Button text="Exportar" onAction="#exportarReporte" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
    </HBox>


</VBox>